# ── Application ──────────────────────────────────────────────────────────
APP_NAME=O9
APP_ENV=production            # production | staging | local | testing
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=UTC
APP_DEFAULT_LOCALE=en
APP_FALLBACK_LOCALE=en

# ── Security ─────────────────────────────────────────────────────────────
# Minimum 32 random characters. The app REFUSES to boot in production with a
# weak or placeholder value.
JWT_SECRET=
JWT_TTL=86400
SESSION_NAME=o9_session

# Base64 of exactly 32 random bytes (e.g. `openssl rand -base64 32`), or let
# setup/setup.php generate one. Keys Security\Crypto (secrets-at-rest, e.g.
# payment provider credentials — fails closed if this is missing) and
# Hashid's token alphabet. Rotating it invalidates every existing enc: value
# and every previously issued Hashid token.
APP_KEY=

# ── Database ─────────────────────────────────────────────────────────────
# DB_DATABASE is intentionally NOT set here — config/database.php already
# picks the right default per driver (storage/database/o9.sqlite for
# sqlite, 'o9' for mysql). A value here would apply to BOTH drivers (env()
# only falls through to that per-driver default when the key is absent,
# not when it's present-but-blank), and a MySQL-style database name is not
# a usable sqlite file path. Uncomment and set only if you need something
# other than the default for your active driver.
DB_DRIVER=sqlite              # sqlite | mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ── Cache / Redis ────────────────────────────────────────────────────────
CACHE_DRIVER=file             # redis | file | array
CACHE_PREFIX=o9
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
SESSION_REDIS=false

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=warning             # error | warning | info | debug
LOG_DB_MIRROR=true

# ── Storage (spec §Driver Patterns / §Transparent Fallback) ─────────────
STORAGE_PRIMARY=local         # local | s3 | sftp | webdav | ftp
STORAGE_BACKENDS=             # comma-separated backends to boot, e.g. "local,s3"
STORAGE_FALLBACK=             # comma-separated read-fallback order, tried after STORAGE_PRIMARY
STORAGE_MODE=primary          # primary | all | sync

S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_KEY=
S3_SECRET=

# ── Mail ─────────────────────────────────────────────────────────────────
MAIL_DRIVER=log                    # log | mail | smtp | mailgun
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=tls                # tls | ssl | none
SMTP_USERNAME=
SMTP_PASSWORD=
MAILGUN_DOMAIN=
MAILGUN_SECRET=

# ── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=240         # non-GET requests per minute per IP
RATE_LIMIT_AUTH=5             # auth attempts per 5 minutes per IP

# ── Kernel gates (all optional) ─────────────────────────────────────────
FORCE_HTTPS=true
MAINTENANCE_MODE=false
GEOBLOCK_COUNTRIES=           # comma-separated ISO codes to block

# Shared secret for Controllers\Admin\CronController's HTTP-triggered
# schedule:run fallback (for hosts without shell/crontab access). Empty
# (default) refuses every request — see setup/scripts/cron.sh for the
# normal crontab-based path.
CRON_SECRET=

# ── Telegram bot (routes/bot.php, app/Controllers/Bot/*) ────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=      # set via setWebhook's secret_token param; blank accepts any webhook call
TELEGRAM_ADMIN_IDS=           # comma-separated Telegram user ids allowed to run AdminBotController commands

# ── AI (app/Ai/* — AiProviderFactory, OpenAiProvider) ──────────────────
AI_PROVIDER=openai            # openai | custom (register via AiProviderFactory::extend)
AI_DEFAULT_MODEL=gpt-4o
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1   # swap for Ollama/Groq/vLLM/Claude proxy
OPENAI_MODEL=                 # per-provider model override
OPENAI_TIMEOUT=60

# ── Notifications (app/Notifications/* — WebhookChannel) ──────────────
NOTIFICATION_WEBHOOK_URL=     # default URL for WebhookChannel
