#!/usr/bin/env php
<?php
declare(strict_types=1);

/**
 * Unified CLI entrypoint. Bootstraps once, registers commands, dispatches:
 *   php setup/bin/console <command> [args]   (no command -> list)
 */
define('BASE_PATH', dirname(__DIR__, 2));

if (is_file(BASE_PATH . '/vendor/autoload.php')) {
    require BASE_PATH . '/vendor/autoload.php';
} else {
    require BASE_PATH . '/app/Core/Autoloader.php';
    App\Core\Autoloader::register();
    require BASE_PATH . '/app/Core/helpers.php';
}
require BASE_PATH . '/config/env.php';

$kernel = new App\Console\Kernel();

$kernel->register(new App\Console\Commands\MigrateCommand());
$kernel->register(new App\Console\Commands\QueueWorkCommand());
$kernel->register(new App\Console\Commands\ScheduleRunCommand());
$kernel->register(new App\Console\Commands\CacheClearCommand());
$kernel->register(new App\Console\Commands\MakeControllerCommand());
$kernel->register(new App\Console\Commands\MakeModelCommand());
$kernel->register(new App\Console\Commands\MakeMiddlewareCommand());
$kernel->register(new App\Console\Commands\MakeJobCommand());
$kernel->register(new App\Console\Commands\SeedCommand());

exit($kernel->handle($argv));
