{
    "name": "o9/framework",
    "description": "O9 — zero-dependency PHP framework: routing, database, cache, queue, storage drivers, i18n, security, console.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^10.5"
    },
    "suggest": {
        "ext-redis": "Redis cache store, Redis sessions and atomic rate limiting",
        "ext-intl": "Locale-aware number/date formatting in i18n helpers"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Core/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=1G"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
